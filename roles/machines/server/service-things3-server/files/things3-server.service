[Unit]
Description=Things3 webserver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=XDG_STATE_HOME=/var/lib/things3-server
EnvironmentFile=/etc/things3-auth.conf
StateDirectory=things3-server
ExecStart=/usr/bin/things3 webserver --host 127.0.0.1 --port 8765
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
